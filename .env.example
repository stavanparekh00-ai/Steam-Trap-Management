# Copy to ".env" for local development, or set in Vercel / Netlify.

# --- Cloud mode (shared, live data for a team) -----------------------------
# When BOTH are set, the app uses Supabase: shared dataset, real-time sync.
# Create users in Supabase Auth (Authentication → Users) to sign in.
# Run supabase/schema.sql once in the Supabase SQL Editor.
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Local mode (single static login, per-browser data) --------------------
# Used only when Supabase is NOT configured. Defaults: admin / tamu-steam-2026
# VITE_APP_USERNAME=admin
# VITE_APP_PASSWORD=choose-a-strong-password
